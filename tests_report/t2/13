mkdir -p outs/t2/13
for s in samples/13/*; do \
	out=${s##*/}; \
	echo "=============================="; \
	echo "Running: $s"; \
	LIMIT_BYTES=$(( 200 * 1024 * 1024 * 1024 )); \
	if /usr/bin/time -f "Elapsed: %E\nCPU: %P\nMax memory: %M KB" \
		prlimit --as=$LIMIT_BYTES ./bin/bin 2 < $s > "outs/t2/13/$out"; \
	then \
		echo "OK: $s"; \
	else \
		echo "Skipped/failed due to memory limit or runtime error: $s"; \
	fi; \
done
